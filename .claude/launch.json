{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "cd /d apps\\api && .venv\\Scripts\\python.exe -m app.main"
      ],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
